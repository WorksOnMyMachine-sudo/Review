# 复制本文件为 .env 并填写（.env 已在 .gitignore 中，勿提交）
AMAZON_EMAIL=your_email@example.com
AMAZON_PASSWORD=your_password_here

# 可选：启用低分评论 API 语义分类。不要把真实 Key 提交到 Git。
OPENAI_API_KEY=your_openai_api_key_here
# 如果使用第三方 OpenAI-compatible 服务，在这里填写它的接口地址。
# 例如：https://api.openai.com/v1
# OPENAI_BASE_URL=

# 留空时脚本使用内置默认模型；需要时可在本地 .env 覆盖。
# MaxMini 如需使用 2.7，可在 .env 中设置为 2.7 或服务商要求的完整模型名。
# REVIEW_ANALYSIS_CLASSIFY_MODEL=2.7
# REVIEW_ANALYSIS_TRANSLATE_MODEL=2.7

# 可选：控制单次请求和输出长度。一般不用改；数值越低，单次消耗越可控，但太低可能影响长评论判断。
# REVIEW_ANALYSIS_CLASSIFY_BATCH_SIZE=12
# REVIEW_ANALYSIS_CLASSIFY_MAX_TOKENS=1200
# REVIEW_ANALYSIS_TRANSLATE_BATCH_SIZE=20
# REVIEW_ANALYSIS_TRANSLATE_MAX_TOKENS=1000
# REVIEW_ANALYSIS_API_TIMEOUT_SECONDS=240
# REVIEW_ANALYSIS_API_RETRIES=3
